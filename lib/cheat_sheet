int get_strlen(const char *string)
{
    int size = 0;

    while (string[size] != '\0')
    {
        size++;
    }

    return size;
}

int match_ends(const int n, const char *words[])
{
    int count = 0;

    for (int i = 0; i < n; i++)
    {
        int len = get_strlen(words[i]);

        if (len >= 2 && words[i][0] == words[i][len - 1])
        {
            count++;
        }
    }

    return count;
}

int char_count(const char *s, const char c)
{
    int count = 0;

    for (int i = 0; s[i] != '\0'; i++)
    {
        if (s[i] == c)
        {
            count++;
        }
    }

    return count;
}

int rfind_char(const char *s, const char c)
{
    int length = get_strlen(s);

    for (int i = length - 1; i >= 0; i--)
    {
        if (s[i] == c)
        {
            return i;
        }
    }

    return -1;
}

void fill_ascii_array(char arr[])
{
    for (int i = 0; i < ALPHABET_LENGTH; i++)
    {
        arr[i] = 'a' + i;
    }
}

void fill_ascii_string(char str[])
{
    for (int i = 0; i < ALPHABET_LENGTH; i++)
    {
        str[i] = 'a' + i;
    }
    str[ALPHABET_LENGTH] = '\0';
}

int contains_char(const char *s, const char c)
{
    for (int i = 0; s[i] != '\0'; i++)
    {
        if (s[i] == c)
        {
            return 1;
        }
    }

    return 0;
}

int contains(const int arr[], const int size, const int target)
{
    for (int i = 0; i < size; i++)
    {
        if (arr[i] == target)
        {
            return 1;
        }
    }

    return 0;
}

int find_index(const int arr[], const int size, int target)
{
    for (int i = 0; i < size; i++)
    {
        if (arr[i] == target)
        {
            return i;
        }
    }

    return -1;
}

