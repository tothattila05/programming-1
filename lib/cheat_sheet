int valid_triangle(const double a, const double b, const double c)
{
    if (a <= 0 || b <= 0 || c <= 0)
    {
        printf("\nHiba: A haromszog oldalainak pozitiv szamoknak kell lenniuk!\n");
        return 0;
    }

    if ((a + b > c) && (a + c > b) && (b + c > a))
    {
        return 1;
    }

    return 0;
}

int is_sorted(const int arr[], const int size)
{
    if (size <= 1)
    {
        return 1;
    }

    for (int i = 0; i < size - 1; i++)
    {
        if (arr[i] > arr[i + 1])
        {
            return 0;
        }
    }

    return 1;
}

int get_min(const int arr[], const int size)
{
    int min = arr[0];

    for (int i = 1; i < size; i++)
    {
        if (arr[i] < min)
        {
            min = arr[i];
        }
    }

    return min;
}

int get_max(const int arr[], const int size)
{
    int max = arr[0];

    for (int i = 1; i < size; i++)
    {
        if (arr[i] > max)
        {
            max = arr[i];
        }
    }

    return max;
}

int get_absolute(int n)
{
    if (n < 0)
    {
        return -n;
    }
    return n;
}

int calculate_difference(const int heights[], const int size)
{
    int sum = 0;

    for (int i = 0; i < size - 1; i++)
    {
        int diff = heights[i] - heights[i + 1];
        sum += get_absolute(diff);
    }

    return sum;
}

int is_even(int n)
{
    if (n % 2 == 0)
    {
        return 1;
    }

    return 0;
}

int is_odd(int n)
{
    if (is_even(n) == 0)
    {
        return 1;
    }

    return 0;
}

